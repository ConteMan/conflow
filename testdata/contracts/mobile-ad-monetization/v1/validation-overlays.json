{
  "contract_version": 1,
  "pack_ref": "mobile-ad-monetization/v1",
  "base_fixture": "entities.json",
  "description": "Validation and deletion scenarios layered over the canonical entities fixture. Each overlay is independently reproducible and consumable by Go golden tests, API tests, and UI E2E.",
  "diagnostic_sort": ["blocking", "error", "warning", "info"],
  "severity_contract": {
    "info": {"cli_exit_code": 0, "readiness_effect": "none", "ui_category": "suggestion"},
    "warning": {"cli_exit_code": 0, "readiness_effect": "none", "ui_category": "warning"},
    "error": {"cli_exit_code": 1, "readiness_effect": "blocked", "ui_category": "blocking"},
    "blocking": {"cli_exit_code": 2, "readiness_effect": "blocked", "ui_category": "blocking"}
  },
  "scenarios": [
    {
      "id": "nine-human-fixture-diagnostics",
      "environment_id": "production",
      "overlay": {
        "entity_replacements": [
          {"entity_type": "placement", "entity_id": "ad_app_open_001", "fields": {"load_timeout_ms": 500}},
          {"entity_type": "placement", "entity_id": "ad_native_007", "fields": {"network_mode": "auction"}},
          {"entity_type": "feature_switch", "entity_id": "use_amazon_bidding", "fields": {"default_value": "enabled"}},
          {"entity_type": "placement", "entity_id": "ad_native_001", "fields": {"frequency_policy_id": "native_scroll_gap_deleted"}}
        ],
        "deleted_entity_refs": ["entity:mobile-ad-monetization/v1:frequency_policy:native_scroll_gap"],
        "delete_attempts": ["entity:mobile-ad-monetization/v1:frequency_policy:inter_global_cap"]
      },
      "expected": {
        "readiness": "blocked",
        "cli_exit_code": 2,
        "diagnostics": [
          {"code": "production_enabled_placements_unbound", "path": "/unit_bindings", "severity": "blocking"},
          {"code": "feature_switch_default_not_boolean", "path": "/feature_switches/use_amazon_bidding/default_value", "severity": "error", "entity_ref": "entity:mobile-ad-monetization/v1:feature_switch:use_amazon_bidding"},
          {"code": "frequency_policy_still_referenced", "path": "/frequency_policies/inter_global_cap", "severity": "error", "entity_ref": "entity:mobile-ad-monetization/v1:frequency_policy:inter_global_cap"},
          {"code": "load_timeout_out_of_range", "path": "/placements/ad_app_open_001/load_timeout_ms", "severity": "error", "entity_ref": "entity:mobile-ad-monetization/v1:placement:ad_app_open_001"},
          {"code": "reference_not_found", "path": "/placements/ad_native_001/frequency_policy_id", "severity": "error", "entity_ref": "entity:mobile-ad-monetization/v1:placement:ad_native_001"},
          {"code": "network_mode_not_allowed", "path": "/placements/ad_native_007/network_mode", "severity": "error", "entity_ref": "entity:mobile-ad-monetization/v1:placement:ad_native_007"},
          {"code": "frequency_policy_unused", "path": "/frequency_policies/legacy_campaign_cap", "severity": "warning", "entity_ref": "entity:mobile-ad-monetization/v1:frequency_policy:legacy_campaign_cap"},
          {"code": "production_unit_binding_missing", "path": "/unit_bindings/ub_production_ios_ad_native_006", "severity": "warning", "entity_ref": "entity:mobile-ad-monetization/v1:unit_binding:ub_production_ios_ad_native_006"},
          {"code": "production_unit_binding_missing", "path": "/unit_bindings/ub_production_ios_ad_native_007", "severity": "warning", "entity_ref": "entity:mobile-ad-monetization/v1:unit_binding:ub_production_ios_ad_native_007"}
        ]
      }
    },
    {
      "id": "restrict-delete-returns-typed-references",
      "environment_id": "production",
      "operation": {
        "method": "DELETE",
        "entity_ref": "entity:mobile-ad-monetization/v1:frequency_policy:inter_global_cap",
        "write_scope": "baseline",
        "if_match": "\"12\"",
        "expected_source_revision": "fixture-source-1"
      },
      "expected": {
        "status": 409,
        "error_code": "entity_referenced",
        "current_revision": 12,
        "references_count": 10,
        "references_subset": [
          {"entity_ref": "entity:mobile-ad-monetization/v1:placement:ad_interstitial_001", "entity_type": "placement", "entity_id": "ad_interstitial_001", "path": "/frequency_policy_id"},
          {"entity_ref": "entity:mobile-ad-monetization/v1:placement:ad_interstitial_010", "entity_type": "placement", "entity_id": "ad_interstitial_010", "path": "/frequency_policy_id"}
        ]
      }
    },
    {
      "id": "validation-result-becomes-stale-after-draft-write",
      "environment_id": "production",
      "given": {"draft_revision": 12, "validated_draft_revision": 12, "validated_at": "2026-07-11T09:30:00Z"},
      "operation": {"method": "PUT", "entity_ref": "entity:mobile-ad-monetization/v1:frequency_policy:app_open_session_gate", "write_scope": "baseline", "fields": {"cooldown_ms": 120000}},
      "expected": {"draft_revision": 13, "diagnostics_status": "stale", "validated_draft_revision": 12, "readiness_is_not_publish_authority": true}
    },
    {
      "id": "large-diff-input",
      "environment_id": "staging",
      "overlay": {
        "entity_replacements": [
          {"entity_type": "frequency_policy", "entity_id": "inter_global_cap", "fields": {"cooldown_ms": 120000}},
          {"entity_type": "feature_switch", "entity_id": "use_amazon_bidding", "fields": {"default_value": true}},
          {"entity_type": "feature_switch", "entity_id": "enable_native_preload", "fields": {"default_value": false}},
          {"entity_type": "feature_switch", "entity_id": "show_subscription_offer", "fields": {"default_value": false}}
        ],
        "environment_override_replacements": [
          {"entity_type": "feature_switch", "entity_id": "use_amazon_bidding", "fields": {"default_value": false}}
        ]
      },
      "expected": {"direct_changes": 5, "affected_entity_refs_count": 10, "affected_entity_type": "placement"}
    }
  ]
}
